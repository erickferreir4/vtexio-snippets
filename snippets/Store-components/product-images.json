{
	"Product Images": {
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Product Images",
		"prefix": "prims",
		"body": [
			"\"product-images\": {",
			"\t\"props\": {",
			"\t\t\"aspectRatio\": \"auto\", // auto | 1:1 | 3:4 | 1920:1080",
			"\t\t\"contentOrder\": \"images-first\", // images-first | videos-first",
			"\t\t\"contentType\": \"all\", // images | videos | all",
			"\t\t\"displayMode\": \"carousel\", // carousel | list | first-image",
			"\t\t\"displayThumbnailsArrows\": false,",
			"\t\t\"hiddenImages\": \"skuvariation\",",
			"\t\t\"maxHeight\": 600,",
			"\t\t\"ModalZoom\": \"modal-layout#product-zoom\",",
			"\t\t\"placeholder\": \"\",",
			"\t\t\"position\": \"left\", // left | right",
			"\t\t\"showNavigationArrows\": true,",
			"\t\t\"showPaginationDots\": true,",
			"\t\t\"thumbnailVisibility\": \"visible\", // visible | hidden",
			"\t\t\"thumbnailAspectRatio\": \"auto\", // auto | 1:1 | 3:4 | 1920:1080",
			"\t\t\"thumbnailMaxHeight\": 150,",
			"\t\t\"thumbnailsOrientation\": \"vertical\",",
			"\t\t\"zoomFactor\": 2,",
			"\t\t\"zoomMode\": \"in-place-click\" // in-place-click | disabled | in-place-hover | open-modal",
			"\t}",
			"},",
			"\"modal-layout#product-zoom\": {",
			"\t\"children\": []",
			"}"
		]
	}
}
