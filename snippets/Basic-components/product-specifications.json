{
	"Product Specifications Group": {
		"scope": "jsonc",
		"prefix": "prspeg",
		"description": "VTEXIO - Defines a Product Specifications Group",
		"body": [
			"\"product-specification-group\": {",
			"\t\"props\": {",
			"\t\t\"filter\": {",
			"\t\t\t//\"specificationGroups\": []",
			"\t\t\t//\"type\": \"\" // hide | show",
			"\t\t}",
			"\t},",
			"\t\"children\": [",
			"\t\t\"product-specification-text#group\",",
			"\t\t\"product-specification\"",
			"\t]",
			"},",
			"\"product-specification-text#group\": {",
			"\t\"props\": {",
			"\t\t\"message\": \"{groupName}\",",
			"\t\t\"markers\": [],",
			"\t\t\"blockClass\": \"text-group\"",
			"\t}",
			"},",
			"\"product-specification\": {",
			"\t\"children\": [",
			"\t\t\"product-specification-values\",",
			"\t\t\"product-specification-text#specification\"",
			"\t]",
			"},",
			"\"product-specification-values\": {",
			"\t\"children\": [",
			"\t\t\"product-specification-text#value\"",
			"\t]",
			"},",
			"\"product-specification-text#value\": {",
			"\t\"props\": {",
			"\t\t\"message\": \"{specificationValue}\"",
			"\t}",
			"},",
			"\"product-specification-text#specification\": {",
			"\t\"props\": {",
			"\t\t\"message\": \"specificationName\"",
			"\t}",
			"},"
		]
	}
}
