{
	"Header": {
		"prefix": "headr",
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Header",
		"body": [
			"\"header\": {",
			"\t\"blocks\": [",
			"\t\t\"header-layout.desktop\",",
			"\t\t\"header-layout.mobile\"",
			"\t]",
			"},",
			"\"header-layout.mobile\": {",
			"\t\"children\": [",
			"\t\t\"header-row#1-mobile\"",
			"\t]",
			"},",
			"\"header-layout.desktop\": {",
			"\t\"children\": [",
			"\t\t\"header-row#1-desktop\",",
			"\t\t\"header-row#2-desktop\",",
			"\t\t\"header-row#3-desktop\"",
			"\t]",
			"},",
			"\"header-row#1-desktop\": {",
			"\t\"children\": [",
			"\t\t\"telemarketing\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"fullWidth\": true,",
			"\t\t\"zIndex\": 0,",
			"\t\t\"sticky\": false,",
			"\t\t\"inverted\": false",
			"\t}",
			"},",
			"\"header-row#2-desktop\": {",
			"\t\"children\": [",
			"\t\t\"header-border\",",
			"\t\t\"notification.bar#home\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"fullWidth\": true,",
			"\t\t\"zIndex\": 0,",
			"\t\t\"sticky\": false,",
			"\t\t\"inverted\": false",
			"\t}",
			"},",
			"\"notification.bar#home\": {",
			"\t\"props\": {",
			"\t\t\"content\": \"SELECTED ITEMS ON SALE! CHECK IT OUT!\"",
			"\t}",
			"},",
			"\"header-row#3-desktop\": {",
			"\t\"children\": [",
			"\t\t\"header-force-center\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"main-header\",",
			"\t\t\"horizontalAlign\": \"center\",",
			"\t\t\"verticalAlign\": \"center\",",
			"\t\t\"preventHorizontalStretch\": true,",
			"\t\t\"preventVerticalStretch\": true,",
			"\t\t\"fullWidth\": true",
			"\t}",
			"},",
			"\"header-force-center\": {",
			"\t\"children\": [",
			"\t\t\"logo#desktop\"",
			"\t]",
			"},",
			"\"logo#desktop\": {",
			"\t\"props\": {",
			"\t\t\"title\": \"Logo\",",
			"\t\t\"href\": \"/\",",
			"\t\t\"url\": \"https://storecomponents.vteximg.com.br/arquivos/store-theme-logo.png\",",
			"\t\t\"width\": \"180\"",
			"\t}",
			"},",
			"\"header-row#1-mobile\": {",
			"\t\"children\": [",
			"\t\t\"telemarketing\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"fullWidth\": true,",
			"\t\t\"zIndex\": 0,",
			"\t\t\"sticky\": false,",
			"\t\t\"inverted\": false",
			"\t}",
			"},"
		]
	}
}