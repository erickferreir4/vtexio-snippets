{
	"Banner Search": {
		"prefix": "banns",
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Banner in Search Context",
		"body": [
			"\"flex-layout.row#banner-one-${1:name}\": {",
			"\t\"children\": [",
			"\t\t\"search-banner#one-$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"banner-one-$1\"",
			"\t}",
			"},",
			"\"search-banner#one-$1\": {",
			"\t\"props\": {",
			"\t\t\"area\": \"one\",",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"horizontalAlignment\": \"center\" // center | left | right",
			"\t}",
			"},"
		]
	}
}