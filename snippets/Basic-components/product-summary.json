{
	"Product Summary Self": {
		"scope": "jsonc",
		"prefix": "prsu",
		"description": "VTEXIO - Defines a Product Summary Self",
		"body": [
			"\"list-context.product-list\": {",
			"\t\"blocks\": [\"product-summary.shelf\"],",
			"\t\"props\": {",
			"\t\t//\"category\": \"-\",",
			"\t\t//\"specificationFilters\": [],",
			"\t\t//\"collection\": \"\",",
			"\t\t//\"listName\": \"\",",
			"\t\t\"orderBy\": \"OrderByTopSaleDESC\", // OrderByTopSaleDESC | OrderByReleaseDateDESC | OrderByBestDiscountDESC | OrderByPriceDESC | OrderByPriceASC | OrderByNameASC | OrderByNameDESC",
			"\t\t\"hideUnavailableItems\": false,",
			"\t\t\"maxItems\": 10,",
			"\t\t\"skusFilter\": \"ALL_AVAILABLE\", // ALL_AVAILABLE | FIRST_AVAILABLE | ALL",
			"\t\t\"installmentCriteria\": \"MAX_WITHOUT_INTEREST\", // MAX_WITHOUT_INTEREST | MAX_WITH_INTEREST",
			"\t\t\"preferredSKU\": \"FIRST_AVAILABLE\" // FIRST_AVAILABLE | LAST_AVAILABLE | PRICE_ASC | PRICE_DESC",
			"\t}",
			"},",
			"\"product-summary.shelf\": {",
			"\t\"children\": [",
			"\t\t\"product-summary-name\",",
			"\t\t\"product-summary-description\",",
			"\t\t\"product-summary-image\",",
			"\t\t\"product-summary-price\",",
			"\t\t\"product-summary-sku-selector\",",
			"\t\t\"product-summary-buy-button\"",
			"\t]",
			"},"
		]
	},
	"Product Summary Buy Button": {
		"scope": "jsonc",
		"prefix": "prsubu",
		"description": "VTEXIO - Defines a Product Summary Buy Button",
		"body": [
			"\"product-summary-buy-button\": {",
			"\t\"props\": {",
			"\t\t\"isOneClickBuy\": false,",
			"\t\t\"buyButtonText\": \"BUY\",",
			"\t\t\"displayBuyButton\": \"displayButtonAlways\", // displayButtonAlways | displayButtonHover | displayButtonNone",
			"\t\t\"customToastURL\": \"/checkout/#/cart\",",
			"\t\t\"buyButtonBehavior\": \"default\"// default | alwaysGoToProduct | alwaysAddToTheCart ",
			"\t}",
			"},"
		]
	},
