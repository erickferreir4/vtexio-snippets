	"Product Selling Price": {
		"prefix": "prsp",
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Product Selling Price",
		"body": [
			"\"product-selling-price#summary\": {",
			"\t\"props\": {",
			"\t\t\"markers\": [",
			"\t\t\t\"highlight\"",
			"\t\t],",
			"\t\t\"blockClass\": \"summary\",",
			"\t\t\"alwaysShow\": false,",
			"\t\t\"message\": \"sellingPriceValue: {sellingPriceValue} sellingPriceWithTax: {sellingPriceWithTax} sellingPriceWithUnitMultiplier: {sellingPriceWithUnitMultiplier} taxPercentage: {taxPercentage} taxValue: {taxValue}  sellingPriceWithUnitMultiplier: {sellingPriceWithUnitMultiplier} sellingPriceWithTax: {sellingPriceWithTax} sellingPriceValue: {sellingPriceValue} hasUnitMultiplier: {hasMeasurementUnit, select, true { / {hasUnitMultiplier, select, true {{unitMultiplier}} false {}} {measurementUnit}} false {}}\"",
			"\t}",
			"}"
		]
	},
