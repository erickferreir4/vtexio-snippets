{
	"Search Bar": {
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Search Bar",
		"prefix": "searb",
		"body": [
			"\"search-bar\": {",
			"\t\"blocks\": [\"autocomplete-result-list.v2\"],",
			"\t\"props\": {",
			"\t\t\"openAutocompleteOnFocus\": true",
			"\t}",
			"},",
			"\"autocomplete-result-list.v2\": {",
			"\t\"props\": {",
			"\t\t\"maxTopSearches\": 10,",
			"\t\t\"maxHistory\": 5,",
			"\t\t\"maxSuggestedProducts\": 3,",
			"\t\t\"maxSuggestedTerms\": 3,",
			"\t\t\"autocompleteWidth\": 100,",
			"\t\t\"productLayout\": \"HORIZONTAL\", // HORIZONTAL | VERTICAL",
			"\t\t\"hideTitles\": false,",
			"\t\t\"hideUnavailableItems\": false,",
			"\t\t\"historyFirst\": false,",
			"\t\t\"simulationBehavior\": \"default\"",
			"\t\t//\"HorizontalProductSummary\": \"\" // customized 'product-summary' block here",
			"\t}",
			"}"
		]
	},
	"Search Result Layout": {
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Search Result Layout",
		"prefix": "searl",
		"body": [
			"\"search-result-layout.desktop\": {",
			"\t\"children\": [",
			"\t\t\"flex-layout.row#did-you-mean\",",
			"\t\t\"flex-layout.row#suggestion\",",
			"\t\t\"flex-layout.row#banner-one\",",
			"\t\t\"flex-layout.row#result\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"pagination\": \"show-more\",",
			"\t\t\"preventRouteChange\": true,",
			"\t\t\"mobileLayout\": {",
			"\t\t\t\"mode1\": \"small\",",
			"\t\t\t\"mode2\": \"normal\"",
			"\t\t}",
			"\t}",
			"},",
			"\"flex-layout.row#did-you-mean\": {",
			"\t\"children\": [\"did-you-mean\"]",
			"},",
			"\"flex-layout.row#suggestion\": {",
			"\t\"children\": [\"search-suggestions\"]",
			"},",
			"\"flex-layout.row#banner-one\": {",
			"\t\"children\": [\"search-banner#one\"]",
			"},",
			"\"search-banner#one\": {",
			"\t\"props\": {",
			"\t\t\"area\": \"one\",",
			"\t\t\"blockClass\": \"myBanner\",",
			"\t\t\"horizontalAlignment\": \"center\"",
			"\t}",
			"}"
		]
	},
	"Filter Navigator": {
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Filter Results",
		"prefix": "filn",
		"body": [
			"\"filter-navigator.v3\": {",
			"\t\"props\": {",
			"\t\t\"categoryFiltersMode\": \"default\", // default | href",
			"\t\t\"layout\": \"responsive\", // responsive | desktop",
			"\t\t\"maxItemsDepartment\": 8,",
			"\t\t\"maxItemsCategory\": 8,",
			"\t\t\"initiallyCollapsed\": false,",
			"\t\t\"openFiltersMode\": \"many\",",
			"\t\t\"filtersTitleHtmlTag\": \"h5\",",
			"\t\t\"scrollToTop\": \"none\", // none | smooth | auto",
			"\t\t\"truncateFilters\": false,",
			"\t\t\"closeOnOutsideClick\": false,",
			"\t\t\"appliedFiltersOverview\": \"hide\", // hide | show",
			"\t\t\"totalProductsOnMobile\": \"hide\", // hide | show",
			"\t\t\"fullWidthOnMobile\": false,",
			"\t\t\"navigationTypeOnMobile\": \"page\", // page | collapsible",
			"\t\t\"updateOnFilterSelectionOnMobile\": false,",
			"\t\t\"showClearByFilter\": false,",
			"\t\t\"priceRangeLayout\": \"slider\" // slider | inputAndSlider",
			"\t}",
			"}"
		]
	},
	"Search Result Custom": {
		"prefix": "searlc",
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Search Result Layout Custom",
		"body": [
			"\"search-result-layout.customQuery#${1:name}\": {",
			"\t\"props\": {",
			"\t\t\"querySchema\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\", // default | skip",
			"\t\t\t\"maxItemsPerPage\": 10,",
			"\t\t\t\"orderByField\": \"OrderByScoreDESC\", // OrderByScoreDESC | OrderByReleaseDateDESC | OrderByBestDiscountDESC | OrderByPriceDESC | OrderByPriceASC | OrderByNameASC | OrderByNameDESC",
			"\t\t\t\"hideUnavailableItems\": false,",
			"\t\t\t\"facetsBehavior\": \"Static\", // Static | Dynamic",
			"\t\t\t\"installmentCriteria\": \"MAX_WITHOUT_INTEREST\" // MAX_WITHOUT_INTEREST | MAX_WITH_INTEREST",
			"\t\t\t//\"queryField\": \"\",",
			"\t\t\t//\"mapField\": \"\",",
			"\t\t\t//\"excludedPaymentSystems\": \"\",",
			"\t\t\t//\"includedPaymentSystems\": \"\"",
			"\t\t}",
			"\t}",
			"}"
		]
	},
	"Store Search": {
		"prefix": "stors",
		"scope": "jsonc",
		"description": "VTEXIO - Defines a Store Search Pages",
		"body": [
			"\"store.search\": {",
			"\t\"blocks\": [\"search-result-layout\"],",
			"\t\"props\": {",
			"\t\t\"context\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\"",
			"\t\t}",
			"\t}",
			"},",
			"\"store.search#category\": {",
			"\t\"blocks\": [\"search-result-layout\"],",
			"\t\"props\": {",
			"\t\t\"context\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\"",
			"\t\t}",
			"\t}",
			"},",
			"\"store.search#brand\": {",
			"\t\"blocks\": [\"search-result-layout\"],",
			"\t\"props\": {",
			"\t\t\"context\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\"",
			"\t\t}",
			"\t}",
			"},",
			"\"store.search#department\": {",
			"\t\"blocks\": [\"search-result-layout\"],",
			"\t\"props\": {",
			"\t\t\"context\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\"",
			"\t\t}",
			"\t}",
			"},",
			"\"store.search#subcategory\": {",
			"\t\"blocks\": [\"search-result-layout\"],",
			"\t\"props\": {",
			"\t\t\"context\": {",
			"\t\t\t\"skusFilter\": \"FIRST_AVAILABLE\", // FIRST_AVAILABLE | ALL_AVAILABLE | ALL",
			"\t\t\t\"simulationBehavior\": \"default\"",
			"\t\t}",
			"\t}",
			"}"
		]
	}
}
