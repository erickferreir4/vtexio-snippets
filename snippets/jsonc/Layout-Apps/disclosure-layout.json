{
	"Disclosure Layout": {
		"prefix": "discl",
		"description": "VTEXIO - Defines a Disclosure Layout",
		"scope": "jsonc",
		"body": [
			"\"disclosure-layout#${1:name}\": {",
			"\t\"children\": [\"disclosure-trigger#$1\", \"disclosure-content#$1\", \"disclosure-state-indicator#$1\"],",
			"\t\"props\": {",
			"\t\t\"initialVisibility\": \"hidden\", // hidden | visible",
			"\t\t\"animated\": false",
			"\t}",
			"},",
			"\"disclosure-trigger#$1\": {",
			"\t\"children\": [\"rich-text#question-$1\"],",
			"\t\"props\": {",
			"\t\t\"as\": \"button\", // HTML tag", 
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"disclosure-content#$1\": {",
			"\t\"children\": [\"rich-text#answer-$1\"],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"disclosure-state-indicator#$1\": {",
			"\t\"props\": {",
			"\t\t\"Show\": \"rich-text#icon-angle--up-$1\",",
			"\t\t\"Hide\": \"rich-text#icon-angle--down-$1\"",
			"\t}",
			"},",
			"\"rich-text#icon-angle--up-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"icon-angle--up-$1\",",
			"\t\t\"text\": \"+\"",
			"\t}",
			"},",
			"\"rich-text#icon-angle--down-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"icon-angle--down-$1\",",
			"\t\t\"text\": \"-\"",
			"\t}",
			"},",
			"\"rich-text#question-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"question-$1\",",
			"\t\t\"text\": \"How can I change my shipping address?\"",
			"\t}",
			"},",
			"\"rich-text#answer-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"answer-$1\",",
			"\t\t\"text\": \"Call us at the number (212) 1234-1234\"",
			"\t}",
			"}"
		]
	},
	"Disclosure Layout Group": {
		"prefix": "disclg",
		"description": "VTEXIO - Defines a Disclosure Layout Group",
		"scope": "jsonc",
		"body": [
			"\"disclosure-layout-group#${1:name}\": {",
			"\t\"children\": [\"disclosure-layout#first-$1\", \"disclosure-layout#second-$1\"]",
			"},",
			"\"disclosure-state-indicator#$1\": {",
			"\t\"props\": {",
			"\t\t\"Show\": \"rich-text#icon-angle--up-$1\",",
			"\t\t\"Hide\": \"rich-text#icon-angle--down-$1\"",
			"\t}",
			"},",
			"\"rich-text#icon-angle--up-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"icon-angle--up-$1\",",
			"\t\t\"text\": \"+\"",
			"\t}",
			"},",
			"\"rich-text#icon-angle--down-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"icon-angle--down-$1\",",
			"\t\t\"text\": \"-\"",
			"\t}",
			"},",
			"\"disclosure-layout#first-$1\": {",
			"\t\"children\": [\"disclosure-trigger#first-$1\", \"disclosure-content#first-$1\", \"disclosure-state-indicator#$1\"],",
			"\t\"props\": {",
			"\t\t\"initialVisibility\": \"hidden\", // hidden | visible",
			"\t\t\"animated\": false",
			"\t}",
			"},",
			"\"disclosure-trigger#first-$1\": {",
			"\t\"children\": [\"rich-text#first-question-$1\"],",
			"\t\"props\": {",
			"\t\t\"as\": \"button\", // HTML tag", 
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"disclosure-content#first-$1\": {",
			"\t\"children\": [\"rich-text#first-answer-$1\"],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"disclosure-layout#second-$1\": {",
			"\t\"children\": [\"disclosure-trigger#second-$1\", \"disclosure-content#second-$1\", \"disclosure-state-indicator#$1\"],",
			"\t\"props\": {",
			"\t\t\"initialVisibility\": \"hidden\", // hidden | visible",
			"\t\t\"animated\": false",
			"\t}",
			"},",
			"\"disclosure-trigger#second-$1\": {",
			"\t\"children\": [\"rich-text#second-question-$1\"],",
			"\t\"props\": {",
			"\t\t\"as\": \"button\", // HTML tag", 
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"disclosure-content#second-$1\": {",
			"\t\"children\": [\"rich-text#second-answer-$1\"],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\"",
			"\t}",
			"},",
			"\"rich-text#first-question-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"question-$1\",",
			"\t\t\"text\": \"How can I change my shipping address?\"",
			"\t}",
			"},",
			"\"rich-text#first-answer-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"answer-$1\",",
			"\t\t\"text\": \"Call us at the number (212) 1234-1234\"",
			"\t}",
			"},",
			"\"rich-text#second-question-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"question-$1\",",
			"\t\t\"text\": \"How can I change my shipping address?\"",
			"\t}",
			"},",
			"\"rich-text#second-answer-$1\": {",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"answer-$1\",",
			"\t\t\"text\": \"Call us at the number (212) 1234-1234\"",
			"\t}",
			"}"
		]
	}
}
