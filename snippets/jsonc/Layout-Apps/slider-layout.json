{
	"Slider Layout": {
		"prefix": "slidl",
		"description": "VTEXIO - Defines a Slider Layout",
		"scope": "jsonc",
		"body": [
			"\"slider-layout#${1:name}\": {",
			"\t\"title\": \"Slider Layout $1\",",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"itemsPerPage\": {",
			"\t\t\t\"desktop\": 1,",
			"\t\t\t\"tablet\": 1,",
			"\t\t\t\"phone\": 1",
			"\t\t},",
			"\t\t\"label\": \"slider\",",
			"\t\t\"infinite\": true,",
			"\t\t\"showNavigationArrows\": \"always\", // desktopOnly | mobileOnly | always | never",
			"\t\t\"showPaginationDots\": \"always\", // desktopOnly | mobileOnly | always | never",
			"\t\t\"usePagination\": true,",
			"\t\t\"navigationStep\": \"page\", // page | number",
			"\t\t\"fullWidth\": true,",
			"\t\t\"centerModeSlidesGap\": 0,",
			"\t\t\"arrowSize\": {",
			"\t\t\t\"desktop\": 25,",
			"\t\t\t\"mobile\": 25,",
			"\t\t\t\"tablet\": 25,",
			"\t\t\t\"phone\": 25",
			"\t\t},",
			"\t\t\"centerMode\": {",
			"\t\t\t\"desktop\": \"disabled\", // to-the-left | center | disabled ",
			"\t\t\t\"mobile\": \"disabled\",",
			"\t\t\t\"tablet\": \"disabled\",",
			"\t\t\t\"phone\": \"disabled\"",
			"\t\t},",
			"\t\t\"slideTransition\": {",
			"\t\t\t\"speed\": 400,",
			"\t\t\t\"delay\": 0,",
			"\t\t\t\"timing\": \"\"",
			"\t\t},",
			"\t\t\"autoplay\": {",
			"\t\t\t\"timeout\": 4000,",
			"\t\t\t\"stopOnHover\": true",
			"\t\t}",
			"\t},",
			"\t\"children\": [",
			"\t\t\"rich-text#slider-1-$1\",",
			"\t\t\"rich-text#slider-2-$1\",",
			"\t\t\"rich-text#slider-3-$1\"",
			"\t]",
			"},",
			"\"rich-text#slider-1-$1\": {",
			"\t\"title\": \"Rich Text Slider 1 $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Slider 1 $1\"",
			"\t}",
			"},",
			"\"rich-text#slider-2-$1\": {",
			"\t\"title\": \"Rich Text Slider 2 $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Slider 2 $1\"",
			"\t}",
			"},",
			"\"rich-text#slider-3-$1\": {",
			"\t\"title\": \"Rich Text Slider 3 $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Slider 3 $1\"",
			"\t}",
			"}"
		]
	},
