{
	"Sticky Layout": {
		"prefix": "sticl",
		"description": "VTEXIO - Defines a Stick Layout",
		"scope": "jsonc",
		"body": [
			"\"sticky-layout#${1:name}\": {",
			"\t\"title\": \"Stick Layout $1\",",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"verticalSpacing\": 0,",
			"\t\t\"position\": \"bottom\" // bottom | top",
			"\t},",
			"\t\"children\": [",
			"\t\t\"rich-text#$1\"",
			"\t]",
			"},",
			"\"rich-text#$1\": {",
			"\t\"title\": \"Rich Text Stick $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"stick text\"",
			"\t}",
			"}"
		]
	}
}
