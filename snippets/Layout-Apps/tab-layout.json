{
	"Tab Layout": {
		"prefix": "tabl",
		"description": "VTEXIO - Defines a Tab Layout",
		"scope": "jsonc",
		"body": [
			"\"tab-layout#${1:name}\": {",
			"\t\"title\": \"Tab Layout $1\",",
			"\t\"children\": [",
			"\t\t\"tab-list#$1\",",
			"\t\t\"tab-content#$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"defaultActiveTabId\": \"$1-1\"",
			"\t}",
			"},",
			"\"tab-list#$1\": {",
			"\t\"title\": \"Tab List $1\",",
			"\t\"children\": [",
			"\t\t\"tab-list.item#$1-1\",",
			"\t\t\"tab-list.item#$1-2\"",
			"\t]",
			"},",
			"\"tab-list.item#$1-1\": {",
			"\t\"title\": \"Tab Item $1 1\",",
			"\t\"props\": {",
			"\t\t\"tabId\": \"$1-1\",",
			"\t\t\"label\": \"$1 1\",",
			"\t\t\"defaultActiveTab\": true",
			"\t}",
			"},",
			"\"tab-list.item#$1-2\": {",
			"\t\"title\": \"Tab Item $1 2\",",
			"\t\"props\": {",
			"\t\t\"tabId\": \"$1-2\",",
			"\t\t\"label\": \"$1 2\",",
			"\t\t\"defaultActiveTab\": true",
			"\t}",
			"},",
			"\"tab-content#$1\": {",
			"\t\"title\": \"Tab Content $1\",",
			"\t\"children\": [",
			"\t\t\"tab-content.item#$1-1\",",
			"\t\t\"tab-content.item#$1-2\"",
			"\t]",
			"},",
			"\"tab-content.item#$1-1\": {",
			"\t\"title\": \"Tab Content $1 1\",",
			"\t\"children\": [",
			"\t\t\"rich-text#tab-1-$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"tabId\": \"$1-1\"",
			"\t}",
			"},",
			"\"tab-content.item#$1-2\": {",
			"\t\"title\": \"Tab Content $1 2\",",
			"\t\"children\": [",
			"\t\t\"rich-text#tab-2-$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"tabId\": \"$1-2\"",
			"\t}",
			"},",
			"\"rich-text#tab-1-$1\": {",
			"\t\"title\": \"Rich Tab 1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Tab 1 $1\"",
			"\t}",
			"},",
			"\"rich-text#tab-2-$1\": {",
			"\t\"title\": \"Rich Tab 2\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Tab 2 $1\"",
			"\t}",
			"}"
		]
	}
}
