	"Flex Layout Column": {
		"prefix": "flexc",
		"body": [
			"\"flex-layout.col#${1:name}\": {",
			"\t\"title\": \"Flex Col $1\",",
			"\t\"children\": [\n\t\t//blocks...\n\t],",
			"\t\"props\":{",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"borderColor\": \"\", // border color",
			"\t\t\"borderWidth\": \"\", // number",
			"\t\t\"border\": [], // top, right, bottom, left or all",
			"\t\t\"horizontalAlign\": \"\", // left|right|center",
			"\t\t\"marginRight\": \"\", // number",
			"\t\t\"marginLeft\": \"\", // number",
			"\t\t\"paddingRight\": \"\", // number",
			"\t\t\"paddingLeft\": \"\", // number",
			"\t\t\"preventVerticalStretch\": \"\", // Boolean",
			"\t\t\"rowGap\": \"\", // number",
			"\t\t\"verticalAlign\": \"\", // top|middle|bottom",
			"\t\t\"width\": \"\" // percentage or 'grow'",
			"\t}",
			"}"
		],
		"description": "VTEXIO - Defines a Flex Layout Column",
		"scope": "jsonc"
	},
