{
	"Modal Layout": {
		"prefix": "modl",
		"description": "VTEXIO - Defines a Modal Layout",
		"scope": "jsonc",
		"body": [
			"\"modal-trigger#${1:name}\": {",
			"\t\"title\": \"Modal Trigger $1\",",
			"\t\"children\": [",
			"\t\t\"rich-text#$1\",",
			"\t\t\"modal-layout#$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"trigger\": \"click\", // click | load | load-session",
			"\t\t\"customPixelEventId\": \"\", // Store event ID responsible for triggering the modal-trigger",
			"\t\t\"customPixelEventName\": \"\" // Store event name responsible for triggering the modal-trigger",
			"\t}",
			"},",
			"\"rich-text#$1\": {",
			"\t\"title\": \"Rich Text $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Click me\"",
			"\t}",
			"},",
			"\"modal-layout#$1\": {",
			"\t\"title\": \"Modal Layout $1\",",
			"\t\"children\": [",
			"\t\t\"modal-actions.close#$1\",",
			"\t\t\"rich-text#modal-$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"scroll\": \"content\", // content | body",
			"\t\t\"blockClass\": \"$1\",",
			"\t\t\"disableEscapeKeyDown\": false,",
			"\t\t\"fullScreen\": false,",
			"\t\t\"backdrop\": \"clickable\", // clickable | none",
			"\t\t\"customPixelEventId\": \"\", // Store event ID responsible for triggering the modal-layout",
			"\t\t\"customPixelEventName\": \"\" // Store event name responsible for triggering the modal-layout",
			"\t}",
			"},",
			"\"modal-actions.close#$1\": {",
			"\t\"title\": \"Modal Close $1\",",
			"\t\"props\": {",
			"\t\t\"label\": \"cancel\"",
			"\t}",
			"},",
			"\"rich-text#modal-$1\": {",
			"\t\"title\": \"Rich Text Modal $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"Hello\"",
			"\t}",
			"},"
		]
	}
}
