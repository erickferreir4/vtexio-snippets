{
	"Overlay Layout": {
		"prefix": "overl",
		"description": "VTEXIO - Defines an Overlay Layout",
		"scope": "jsonc",
		"body": [
			"\"overlay-trigger#${1:name}\": {",
			"\t\"title\": \"Overlay Trigger $1\",",
			"\t\"children\": [",
			"\t\t\"rich-text#question-$1\",",
			"\t\t\"overlay-layout#$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"trigger\": \"click\" // hover | click",
			"\t}",
			"},",
			"\"rich-text#question-$1\": {",
			"\t\"title\": \"question $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"**Click to open the Overlay Layout**\",",
			"\t\t\"blockClass\": \"question-$1\"",
			"\t}",
			"},",
			"\"overlay-layout#${1:name}\": {",
			"\t\"title\": \"Overlay Layout $1\",",
			"\t\"children\": [",
			"\t\t\"rich-text#link-$1\"",
			"\t],",
			"\t\"props\": {",
			"\t\t\"placement\": \"left\", // left | right | top | bottom",
			"\t\t\"scrollBehavior\": \"default\", // lock-page-scroll | close-on-scroll",
			"\t\t\"backdrop\": \"none\", // none | visible",
			"\t\t\"showArrow\": false,",
			"\t\t\"offsets\": {",
			"\t\t\t\"skidding\": 0,",
			"\t\t\t\"distance\": 0",
			"\t\t}",
			"\t}",
			"},",
			"\"rich-text#link-$1\": {",
			"\t\"title\": \"link $1\",",
			"\t\"props\": {",
			"\t\t\"text\": \"\\n**Reach us at\\n**www.vtex.com.br\",",
			"\t\t\"blockClass\": \"link-$1\"",
			"\t}",
			"},"
		]
	}
}
