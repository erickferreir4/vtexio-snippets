{
	"footer": {
		"blocks": [
			"footer-layout.desktop", "footer-layout.mobile"
		]
	},
	"footer-layout.desktop": {
		"children": [
		]
	},
	"footer-layout.mobile": {
		"children": [
		]
	},
	"flex-layout#footer-desktop": {
		"children": [
			"social-networks",
			"accepted-payment-methods",
			"powered-by"
		]
	},
	"flex-layout#footer-mobile": {
		"children": [
			"social-networks",
			"accepted-payment-methods",
			"powered-by"
		]
	},
	"social-networks": {
		"props": {
			"title": "Social",
			"showInColor": true,
			"socialNetworks": [
				{ "url": "https://facebook.com/foo", "name": "Facebook" },
				{ "url": "https://twitter.com/foo", "name": "Twitter" }
			]
		}
	},
	"accepted-payment-methods": {
		"props": {
			"showInColor": true,
			"paymentMethods": [
				"mastercard",
				"visa",
				"diners club"
			]
		}
	}
}
