{
	"modal-trigger#name": {
		"children": [
			"rich-text#name",
			"modal-layout#name"
		],
		"props": {
			"trigger": "click", // click | load | load-session
			"customPixelEventId": "", // Store event ID responsible for triggering the modal-trigger
			"customPixelEventName": "" // Store event name responsible for triggering the modal-trigger
		}
	},
	"rich-text#name": {
		"props": {
			"text": "Click me"
		}
	},
	"modal-layout#name": {
		"children": [
			"modal-actions.close#name",
			"rich-text#modal-name"
		],
		"props": {
			"scroll": "content", // content | body
			"blockClass": "name",
			"disableEscapeKeyDown": false,
			"fullScreen": false,
			"backdrop": "clickable", // clickable | none
			"customPixelEventId": "", // Store event ID responsible for triggering the modal-layout
			"customPixelEventName": "" // Store event name responsible for triggering the modal-layout
		}
	},
	"modal-actions.close#name": {
		"props": {
			"label": "cancel"
		}
	},
	"rich-text#modal-name": {
		"props": {
			"text": "Hello"
		}
	}
}

